name: Build and Deploy

on:
  push:
    branches: [main]
  workflow_dispatch:

jobs:
  build:
    runs-on: ubuntu-latest
    
    steps:
    - uses: actions/checkout@v3
    
    - name: Setup Node.js
      uses: actions/setup-node@v3
      with:
        node-version: '18'
    
    - name: Generate config.js
      run: |
        sed -e "s|%%ADMIN_PASSWORD%%|${{ secrets.ADMIN_PASSWORD }}|g" \
            -e "s|%%GITHUB_OWNER%%|${{ github.repository_owner }}|g" \
            -e "s|%%GITHUB_REPO%%|${{ github.event.repository.name }}|g" \
            config.template.js > config.js
    
    - name: Deploy to GitHub Pages
      uses: peaceiris/actions-gh-pages@v3
      with:
        github_token: ${{ secrets.GITHUB_TOKEN }}
        publish_dir: ./
        publish_branch: gh-pages